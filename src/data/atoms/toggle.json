  "variants": {
    "default": {
      "description": "Platform bazlı (iOS/Android) toggle görünümü.",
      "tokenMap": {
        "Active": {
          "background": "brand.primary",
          "knob": "inverse.pureWhite"
        },
        "Inactive": {
          "background": "level.elevation +2",
          "knob": "inverse.pureWhite"
        }
      }
    }
  },
  "modeOverrides": {}
