        "Info": {
          "background": "transparent",
          "text": "text.secondary",
          "icon": "icon.inactive"
        },
        "Error": {
          "background": "transparent",
          "text": "actions.action-02",
          "icon": "actions.action-02"
        },
        "Success": {
          "background": "transparent",
          "text": "actions.action-01",
          "icon": "actions.action-01"
        },
        "Warning": {
          "background": "transparent",
          "text": "actions.action-03",
          "icon": "actions.action-03"
        }
      }
    },
    "High": {
      "description": "Dikkat çeken, renkli arkaplana sahip bilgilendirme satırı. Genelde Boxed?=True ile kullanılır.",
      "tokenMap": {
        "Info": {
          "background": "level.elevation +2",
          "text": "text.focus",
          "icon": "icon.focus"
        },
        "Error": {
          "background": "actions.action-02-10%",
          "text": "actions.action-02",
          "icon": "actions.action-02"
        },
        "Success": {
          "background": "actions.action-01-10%",
          "text": "actions.action-01",
          "icon": "actions.action-01"
        },
        "Warning": {
          "background": "actions.action-03-10%",
