{
  "name": "InfoRow",
  "category": "molecule",
  "description": "Bilgilendirme, uyarı veya rehber niteliğindeki metinleri liste içinde veya form aralarında göstermek için kullanılan bilgi satırı.",
  "figmaNodeId": "6GFF7T7fU5i6xDYgvPLX0j / FK-InfoRow",
  "composedOf": ["Typography", "Icon"],
  "states": ["info", "error", "success", "warning"],
  "props": {
    "type": {
      "type": "enum",
      "values": ["Left Align", "Right Align", "Dismissable"],
      "default": "Left Align"
    },
    "presence": {
      "type": "enum",
      "values": ["Low", "High"],
      "default": "Low"
    },
    "tone": {
      "type": "enum",
      "values": ["Info", "Error", "Success", "Warning"],
      "default": "Info"
    },
    "boxed": {
      "type": "boolean",
      "default": true
    },
    "text": { "type": "string" },
    "showIcon": { "type": "boolean", "default": true }
  },
  "variants": {
    "Low": {
      "description": "Daha az dikkat çeken, arkaplanı şeffaf olan bilgilendirme satırı. Genelde Boxed?=False ile kullanılır.",
