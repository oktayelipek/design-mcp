{
  "name": "Price Row",
  "category": "molecule",
  "description": "Fiyat listelerindeki ve emir defterlerindeki her bir satırı (varlık fiyatı, hacim, grafik, değişim oranı) detaylı bir şekilde gösteren bileşen.",
  "figmaNodeId": "ADqYI5EermvB9JpEOByLH9 / Price List Row ½",
