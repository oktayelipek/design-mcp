    "action": {
      "type": "enum",
      "values": ["Buy", "Sell"],
      "default": "Buy"
    },
    "type": {
      "type": "enum",
      "values": ["Default", "Action"],
      "default": "Default"
    },
    "leftMedia": {
      "type": "enum",
      "values": ["Crypto", "Stock", "Fav", "Fav Fill", "None"],
      "default": "Crypto"
